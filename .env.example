# ─── App ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=Your App Name
NEXT_PUBLIC_APP_TAGLINE=Your tagline

# ─── Firebase (client-side — safe to expose) ────────────────────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_VAPID_KEY=

# ─── Sinlung Chat ────────────────────────────────────────────────────────────
# URL of the deployed chat server (no trailing slash)
NEXT_PUBLIC_CHAT_SERVER_URL=https://your-chat-server.vercel.app

# Publishable key from chat-server Platform > Apps (pk_live_...)
# Used for guest / public auth mode
NEXT_PUBLIC_CHAT_PUBLISHABLE_KEY=pk_live_...

# Secret API key from chat-server Platform > Apps (sk_live_...)
# Used server-side only in /api/chat/token to exchange Firebase tokens for chat JWTs
CHAT_SERVER_API_KEY=sk_live_...
